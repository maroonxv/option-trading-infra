@startuml
title 行情工作流 - 顺序图
autonumber

participant "StrategyEntry" as Entry
participant "MarketWorkflow" as Workflow
participant "InstrumentManager" as Instrument
participant "MarketGateway" as Market
participant "IndicatorService" as Indicator
participant "SignalService" as Signal
participant "Decision helpers" as Decision
participant "Observability" as Obs

Entry -> Workflow : on_bars(bars)
Workflow -> Workflow : rollover / universe / timer 检查
Workflow -> Instrument : update_bar(vt_symbol, bar_data)
Instrument --> Workflow : instrument
Workflow -> Market : get_all_contracts / get_tick
Workflow -> Workflow : build_option_chain_snapshot()
Workflow -> Indicator : calculate_bar(...)
Indicator --> Workflow : IndicatorResult
Workflow -> Signal : check_open_signal(...)
Signal --> Workflow : SignalDecision?

opt 开仓信号存在
  Workflow -> Decision : 选约 / Greeks / 定价 / 仓位
  Decision --> Workflow : payloads
  Workflow -> Obs : publish_trace(open)
end

loop 每个 active position
  Workflow -> Signal : check_close_signal(...)
  Signal --> Workflow : SignalDecision?
  opt 平仓信号存在
    Workflow -> Decision : calculate_close_volume(...)
    Workflow -> Obs : publish_trace(close)
  end
end

Workflow -> Obs : record_snapshot / maybe_save
Workflow --> Entry : 完成一轮 bar 处理
@enduml
