@startuml
title 订阅工作流 - 顺序图
autonumber

participant "StrategyEntry" as Entry
participant "SubscriptionWorkflow" as Workflow
participant "MarketGateway" as Market
participant "AccountGateway" as Account
participant "SubscriptionModeEngine" as Engine

Entry -> Workflow : reconcile_subscriptions(trigger)
Workflow -> Market : get_all_contracts()
Workflow -> Workflow : collect_active_signal_symbols()
Workflow -> Account : get_all_positions()
Workflow -> Workflow : collect_pending_order_symbols()
Workflow -> Workflow : get_active_contract_map()
Workflow -> Engine : resolve(context)
Engine --> Workflow : decision

loop 待新增 symbol
  Workflow -> Market : subscribe(symbol)
end

loop stale candidate
  Workflow -> Workflow : 检查 TTL / auto_unsubscribe
  Workflow -> Market : unsubscribe(symbol)
end

Workflow --> Entry : 更新 subscribed / stale 状态
@enduml
