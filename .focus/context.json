{
  "strategy": {
    "name": "main",
    "trading_target": "option-universe",
    "strategy_type": "custom",
    "run_mode": "standalone",
    "summary": "Agent-first strategy workspace for developing and iterating option strategies."
  },
  "manifest_path": "focus/strategies/main/strategy.manifest.toml",
  "packs": [
    "kernel",
    "selection",
    "pricing",
    "risk",
    "execution",
    "hedging",
    "monitoring",
    "web",
    "deploy",
    "backtest"
  ],
  "workflows": {
    "runtime_module": "src.main.main",
    "backtest_module": "src.backtesting.main",
    "monitor_script": "src/web/app.py",
    "workflow_refs": [
      "validation",
      "runtime",
      "backtest",
      "monitoring",
      "focus.smoke",
      "focus.full",
      "deployment"
