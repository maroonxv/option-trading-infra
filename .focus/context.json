    "default_verification_profile": "focus.smoke",
    "expanded_verification_profile": "focus.full"
  },
  "recommended_first_pass": {
    "pack": "selection",
    "entry": "src/strategy/domain/domain_service/selection"
  },
  "surfaces": {
